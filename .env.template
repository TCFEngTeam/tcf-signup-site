# ── Required ──
HUBSPOT_API_KEY=

# ── MHFA pipeline filters ──
HUBSPOT_MHFA_PIPELINE_TYPE=
HUBSPOT_MHFA_PIPELINE_STAGE=
HUBSPOT_MHFA_CLOSED_PIPELINE_STAGE=

# ── QPR pipeline filters (required for /qpr) ──
HUBSPOT_QPR_PIPELINE_TYPE=
HUBSPOT_QPR_PIPELINE_STAGE=
HUBSPOT_QPR_CLOSED_PIPELINE_STAGE=

# ── Training object ──
HUBSPOT_TRAINING_OBJECT_ID=0-410
HUBSPOT_TRAINING_PROPERTIES=hs_pipeline,hs_pipeline_stage,training_1st_day_start_datetime,training_1st_day_end_datetime,training_2nd_day_start_datetime,training_2nd_day_end_datetime,hs_course_name,hs_enrollment_capacity,available_capacity,cutoff_time
HUBSPOT_TRAINING_ASSOCIATION_LABEL=registrant
# Optional numeric type IDs from HubSpot association settings (v4 API)
# HUBSPOT_TRAINING_ASSOCIATION_TYPE_ID=
# HUBSPOT_TRAINING_CANCELLED_ASSOCIATION_TYPE_ID=
# Optional: when UNREGISTER_HUBSPOT_MODE=relabel, label applied after cancellation
HUBSPOT_TRAINING_CANCELLED_ASSOCIATION_LABEL=cancelled_registration

# ── Unregister (/unregister) ──
# Long random string (e.g. openssl rand -base64 32) — signs links; keep secret
UNREGISTER_TOKEN_SECRET=
UNREGISTER_TOKEN_TTL_HOURS=48
# remove = delete registrant link only | relabel = remove registrant + add cancelled label
UNREGISTER_HUBSPOT_MODE=remove
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_UNREGISTER_TOKEN_TTL_HOURS=48
RESEND_API_KEY=
RESEND_FROM_EMAIL=TCF Trainings <trainings@yourdomain.com>

# ── Contact property mappings (only if HubSpot internal names differ) ──
HUBSPOT_FIRST_NAME_PROPERTY=firstname
HUBSPOT_LAST_NAME_PROPERTY=lastname
HUBSPOT_EMAIL_PROPERTY=email
HUBSPOT_PHONE_PROPERTY=phone
HUBSPOT_HOMETOWN_CITY_PROPERTY=hometown_city
HUBSPOT_HOMETOWN_STATE_PROPERTY=hometown_state
HUBSPOT_CURRENT_YEAR_PROPERTY=current_year_in_school
HUBSPOT_VIRGINIA_RESIDENT_PROPERTY=...
HUBSPOT_INTEREST_REASON_PROPERTY=...
HUBSPOT_COMMUNITY_SUPPORT_PROPERTY=...
HUBSPOT_SMS_CONSENT_PROPERTY=...
